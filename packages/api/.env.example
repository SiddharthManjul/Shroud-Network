# Server
PORT=4000

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/shroud_api

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Avalanche RPC
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113

# Relay wallet (funds gas for relayed transactions)
RELAY_PRIVATE_KEY=0x...

# Indexer
INDEXER_URL=http://localhost:8080/v1/graphql

# Circuit files (for server-side proof generation)
CIRCUIT_BASE_PATH=../../circuits/build
