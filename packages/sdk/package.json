{
  "name": "@shroud/sdk",
  "version": "0.1.0",
  "description": "Shroud SDK — Privacy-first shielded pool integration for Avalanche",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin typescript",
    "dev": "rollup -c rollup.config.ts --configPlugin typescript -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "circomlibjs": "^0.1.7",
    "ethers": "^6.16.0",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "tslib": "^2.8.0"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "license": "MIT"
}
